{
  "name": "@poppy/server-ts",
  "version": "0.1.0-alpha.0",
  "description": "TypeScript server library for emitting and validating Poppy documents.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/greg7gkb/poppy.git",
    "directory": "packages/server-ts"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist/", "README.md"],
  "scripts": {
    "compile-schema": "node scripts/compile-schema.mjs",
    "build": "pnpm compile-schema && tsup",
    "typecheck": "tsc --noEmit",
    "test": "pnpm compile-schema && vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@poppy/conformance": "workspace:*",
    "@poppy/schema": "workspace:*",
    "@types/node": "^22.0.0",
    "ajv": "^8.17.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
